<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Scientific Calculator"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnBasic"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Basic Calculator"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_button_operator"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnScientific"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Scientific Calculator"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_button_operator"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnMatrix"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Matrix Calculator"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_button_operator"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnStats"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Statistics &amp; Combinatorics"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_button_operator"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnSettings"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="⚙ Settings"
        android:textColor="#000000"
        android:background="@drawable/bg_button_function"/>

</LinearLayout>
