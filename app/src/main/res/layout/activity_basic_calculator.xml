<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/bg_display"
        android:padding="20dp"
        android:gravity="bottom"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textSize="18sp"
            android:textColor="#888888"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textSize="48sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:text="0"/>

    </LinearLayout>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="5">

        <Button android:id="@+id/btn7" android:text="7" android:textColor="#FFFFFF" android:textSize="22sp" android:background="@drawable/bg_button_number" android:layout_margin="6dp" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="64dp"/>
        <Button android:id="@+id/btn8" android:text="8" android:textColor="#FFFFFF" android:textSize="22sp" android:background="@drawable/bg_button_number" android:layout_margin="6dp" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="64dp"/>
        <Button android:id="@+id/btn9" android:text="9" android:textColor="#FFFFFF" android:textSize="22sp" android:background="@drawable/bg_button_number" android:layout_margin="6dp" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="64dp"/>
        <Button android:id="@+id/btnDivide" android:text="÷" android:textColor="#FFFFFF" android:textSize="24sp" android:background="@drawable/bg_button_operator" android:layout_margin="6dp" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="64dp"/>

        <Button android:id="@+id/btn4" android:text="4" android:textColor="#FFFFFF" android:textSize="22sp" android:background="@drawable/bg_button_number" android:layout_margin="6dp" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="64dp"/>
        <Button android:id="@+id/btn5" android:text="5" android:textColor="#FFFFFF" android:textSize="22sp" android:background="@drawable/bg_button_number" android:layout_margin="6dp" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="64dp"/>
        <Button android:id="@+id/btn6" android:text="6" android:textColor="#FFFFFF" android:textSize="22sp" android:background="@drawable/bg_button_number" android:layout_margin="6dp" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="64dp"/>
        <Button android:id="@+id/btnMultiply" android:text="×" android:textColor="#FFFFFF" android:textSize="24sp" android:background="@drawable/bg_button_operator" android:layout_margin="6dp" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="64dp"/>

        <Button android:id="@+id/btn1" android:text="1" android:textColor="#FFFFFF" android:textSize="22sp" android:background="@drawable/bg_button_number" android:layout_margin="6dp" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="64dp"/>
        <Button android:id="@+id/btn2" android:text="2" android:textColor="#FFFFFF" android:textSize="22sp" android:background="@drawable/bg_button_number" android:layout_margin="6dp" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="64dp"/>
        <Button android:id="@+id/btn3" android:text="3" android:textColor="#FFFFFF" android:textSize="22sp" android:background="@drawable/bg_button_number" android:layout_margin="6dp" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="64dp"/>
        <Button android:id="@+id/btnSubtract" android:text="−" android:textColor="#FFFFFF" android:textSize="24sp" android:background="@drawable/bg_button_operator" android:layout_margin="6dp" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="64dp"/>

        <Button android:id="@+id/btnClear" android:text="C" android:textColor="#000000" android:textSize="22sp" android:background="@drawable/bg_button_function" android:layout_margin="6dp" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="64dp"/>
        <Button android:id="@+id/btn0" android:text="0" android:textColor="#FFFFFF" android:textSize="22sp" android:background="@drawable/bg_button_number" android:layout_margin="6dp" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="64dp"/>
        <Button android:id="@+id/btnDecimal" android:text="." android:textColor="#FFFFFF" android:textSize="22sp" android:background="@drawable/bg_button_number" android:layout_margin="6dp" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="64dp"/>
        <Button android:id="@+id/btnAdd" android:text="+" android:textColor="#FFFFFF" android:textSize="24sp" android:background="@drawable/bg_button_operator" android:layout_margin="6dp" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="64dp"/>

        <Button android:id="@+id/btnBackspace" android:text="⌫" android:textColor="#000000" android:textSize="20sp" android:background="@drawable/bg_button_function" android:layout_margin="6dp" android:layout_columnSpan="4" android:layout_gravity="fill_horizontal" android:layout_width="0dp" android:layout_height="56dp"/>

    </GridLayout>

    <Button
        android:id="@+id/btnEquals"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="10dp"
        android:text="="
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:background="@drawable/bg_button_operator"/>

</LinearLayout>
